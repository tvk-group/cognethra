{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/privacy.html", "destination": "/en/privacy.html", "permanent": true },
    { "source": "/terms.html", "destination": "/en/terms.html", "permanent": true },
    { "source": "/disclaimer.html", "destination": "/en/disclaimer.html", "permanent": true },
    { "source": "/app", "destination": "/en/app/", "permanent": true },
    { "source": "/app/", "destination": "/en/app/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/sitemap-index.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/sitemap-:locale.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    }
  ]
}
